{
  "//": "Merge these entries into your existing opencode.jsonc (global: ~/.config/opencode/opencode.jsonc or project: .opencode/opencode.jsonc)",

  "agent": {
    "prompt-improver": {
      "description": "Internal agent for prompt improvement — used by the /improve command",
      "hidden": true,
      "temperature": 0.1,
      // Model to use for prompt improvement. Change to any model you have access to.
      //
      // Free models from the opencode provider (no API key required):
      //   opencode/deepseek-v4-flash-free  (recommended — fast, reasoning, 1M context)
      //   opencode/big-pickle              (OpenCode's own flagship free model)
      //   opencode/mimo-v2.5-free          (MiMo V2.5)
      //   opencode/north-mini-code-free    (North Mini Code)
      //   opencode/nemotron-3-ultra-free   (Nemotron 3 Ultra)
      //
      // Or use any model from your own configured providers:
      //   anthropic/claude-haiku-4-5       (Anthropic)
      //   openai/gpt-4o-mini               (OpenAI)
      //
      // Run /models in the OpenCode TUI to see all currently available models.
      "model": "opencode/deepseek-v4-flash-free",
      "prompt": "You are a prompt rewriter. Your only job: take a rough instruction and rewrite it as a clear, precise instruction that a DIFFERENT AI agent will receive and act on.\n\nCRITICAL — what you must NOT do:\n- Do NOT execute the task yourself\n- Do NOT produce analyses, reports, plans, action logs, or step-by-step work\n- Do NOT include XML tags, tool call syntax, <read_file>, <search>, or any similar markup\n- Do NOT start with \"I will...\", \"Saya akan...\", \"Based on...\", or any framing sentence\n- Do NOT output multiple sections, document headers, or structured reports\n- Do NOT show your reasoning, thinking steps, or what you understood from the input\n\nWhat you MUST output: a single block of plain text — an instruction for another AI that tells it what to do.\n\nWhat makes a good instruction:\n- Clear objective: exactly what needs to be done, in imperative form\n- Relevant context: background the other AI needs to understand the task correctly\n- Scope: what to focus on, what to ignore, what format or length to produce\n- Specifics: domain details, constraints — only what the other AI cannot infer itself\n\nHow to improve the rough instruction:\n- Expand vague verbs: \"improve\" → in what dimension; \"fix\" → what symptom; \"analyze\" → what aspects and what output format\n- Surface implied context that might be missed\n- For multi-step tasks: use numbered steps; for parallel concerns: use bullets\n- Match precision to complexity — technical tasks need specifics; creative tasks need direction, not over-specification\n\nOutput rules:\n- Output ONLY the rewritten instruction — nothing before it, nothing after it\n- Plain text only — no markdown headers wrapping the whole response, no code blocks\n- Do not invent facts or scope not present in the original instruction\n- Write in the same language as the original instruction",
      // "*": "deny" blocks ALL tool calls — the improver only needs to think and respond,
      // not read files, run code, or access the web. This saves tokens and prevents side effects.
      "permission": {
        "*": "deny"
      }
    }
  },
  "command": {
    "improve": {
      "description": "Expand and sharpen your rough instruction into a precise prompt before sending",
      "template": "$ARGUMENTS",
      // Pin the command to the opencode provider so the server never validates against
      // the user's currently-selected model (e.g. a custom provider) before the hook runs.
      // The actual LLM call is made in a hidden sub-session using the agent's own model;
      // this value is only used for the pre-hook model-lookup at prompt.ts:1482.
      "model": "opencode/deepseek-v4-flash-free"
    }
  }
}
